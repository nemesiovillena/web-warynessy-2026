{
  "name": "squealing-spiral",
  "type": "module",
  "version": "1.0.2",
  "scripts": {
    "dev": "astro dev",
    "dev:all": "concurrently -n \"payload,astro\" -c \"blue,green\" \"next dev -p 3000 --turbopack\" \"astro dev\"",
    "dev:payload": "tsx server.ts",
    "dev:admin": "next dev -p 3000 --turbopack",
    "build": "astro build && next build && npm run build:server",
    "build:astro": "astro build",
    "build:payload": "next build",
    "build:server": "esbuild server.ts --bundle=false --platform=node --format=esm --outfile=server.js",
    "start": "NODE_ENV=production node server.js",
    "preview": "astro preview",
    "astro": "astro",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:rollback": "payload migrate:rollback"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/node": "^9.5.2",
    "@astrojs/sitemap": "^3.6.1",
    "@payloadcms/db-postgres": "3.74.0",
    "@payloadcms/next": "3.74.0",
    "@payloadcms/plugin-cloud-storage": "3.74.0",
    "@payloadcms/richtext-lexical": "3.74.0",
    "@payloadcms/ui": "3.74.0",
    "@seshuk/payload-storage-bunny": "^2.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.16.0",
    "astro": "^5.16.9",
    "deepl-node": "^1.24.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "graphql": "^16.12.0",
    "gsap": "^3.14.2",
    "next": "15.4.10",
    "payload": "3.74.0",
    "pg": "^8.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.8.0",
    "sharp": "^0.34.5",
    "swiper": "^12.0.3",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@types/react": "^19.2.8",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linuxmusl-x64": "^1.1.0",
    "@img/sharp-linuxmusl-x64": "^0.34.5",
    "@next/swc-linux-x64-musl": "15.4.10",
    "@rollup/rollup-linux-x64-musl": "^4.34.6",
    "@tailwindcss/oxide-linux-x64-musl": "^4.1.18",
    "lightningcss": "^1.29.1",
    "lightningcss-linux-x64-musl": "^1.29.1"
  },
  "overrides": {
    "file-type": "18.7.0"
  }
}

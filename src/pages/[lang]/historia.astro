---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import ResponsiveImage from '../../components/ui/ResponsiveImage.astro';
import RichText from '../../components/ui/RichText.astro';
import { getSiteSettings, getPaginaBySlug } from '../../lib/payload-local';

const { lang } = Astro.params;
const locale = lang || 'es';

const siteSettings = await getSiteSettings(locale);
const pageData = await getPaginaBySlug('historia', locale);

const pageTitle = pageData?.metaTitle || `Nuestra Historia | ${siteSettings?.title || "Restaurante Warynessy"}`;
const pageDescription = pageData?.metaDescription || "Conoce la historia y el legado del Restaurante Warynessy.";
---

<MainLayout title={pageTitle} description={pageDescription} noPaddingTop={true}>
  
  <div class="bg-matte-black min-h-screen text-white">
    
    <!-- Hero Section -->
    <section class="relative h-[70vh] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 z-0">
        {pageData?.heroImage ? (
          <ResponsiveImage 
            src={pageData.heroImage.filename ? `https://warynessy.b-cdn.net/${pageData.heroImage.filename}` : pageData.heroImage.url} 
            alt={pageData.heroImage.alt || 'Historia Hero'}
            class="w-full h-full object-cover opacity-50"
          />
        ) : (
          <div class="w-full h-full bg-zinc-900 border border-white/5 flex flex-col items-center justify-center p-8 text-center group">
            <span class="text-white/5 font-display text-9xl font-black mb-2 select-none group-hover:text-primary/10 transition-colors duration-700">W</span>
          </div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-matte-black via-matte-black/60 to-transparent"></div>
      </div>
      
      <div class="relative z-10 text-center px-6 max-w-4xl mx-auto animate-fade-up">
        <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm mb-6 block">Nuestra Historia</span>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-black text-white mb-6 tracking-tighter uppercase leading-none">
          {pageData?.heroTitle || 'Un legado de sabor'}
        </h1>
        {pageData?.heroSubtitle && (
          <p class="text-xl text-gray-400 font-light max-w-2xl mx-auto leading-relaxed">
            {pageData.heroSubtitle}
          </p>
        )}
      </div>
    </section>

    <!-- Misión / Intro -->
    {pageData?.historiaMision && (
      <Section class="bg-matte-black relative pb-24 border-b border-white/5">
        <Container class="text-center max-w-4xl mx-auto relative z-10">
          <span class="material-symbols-outlined text-primary text-5xl mb-8 opacity-50">format_quote</span>
          <p class="text-2xl md:text-4xl font-display font-light text-white leading-tight italic">
            "{pageData.historiaMision}"
          </p>
        </Container>
      </Section>
    )}

    <!-- Hitos Históricos (Timeline) -->
    {pageData?.historiaHitos && pageData.historiaHitos.length > 0 && (
      <Section class="bg-zinc-950 py-32 relative">
        <div class="absolute top-0 bottom-0 left-1/2 w-px bg-white/5 ml-[-0.5px] hidden md:block"></div>
        <Container class="max-w-5xl mx-auto px-6 relative z-10">
          
          <div class="space-y-24 md:space-y-32">
            {pageData.historiaHitos.map((hito: any, index: number) => {
              const isEven = index % 2 === 0;
              return (
                <div class={`flex flex-col md:flex-row items-center justify-between gap-12 md:gap-24 animate-fade-up ${isEven ? 'md:flex-row-reverse' : ''}`} style={`animation-delay: ${index * 150}ms`}>
                  
                  {/* Contenido */}
                  <div class={`w-full md:w-1/2 flex flex-col ${isEven ? 'md:items-start text-left' : 'md:items-end md:text-right text-left'}`}>
                    <div class="flex items-center gap-4 mb-6">
                      <span class="text-primary font-display font-black text-6xl opacity-20">{(index + 1).toString().padStart(2, '0')}</span>
                    </div>
                    <h3 class="text-3xl md:text-5xl font-display font-bold text-white mb-6 uppercase tracking-tight">
                      {hito.titulo}
                    </h3>
                    <p class="text-lg text-gray-400 font-light leading-relaxed">
                      {hito.descripcion}
                    </p>
                  </div>

                  {/* Icono Conector Timeline */}
                  <div class="hidden md:flex absolute left-1/2 -ml-5 w-10 h-10 bg-zinc-950 border border-primary/30 rounded-full items-center justify-center z-10 shadow-[0_0_20px_rgba(236,19,19,0.2)]">
                    <div class="w-3 h-3 bg-primary rounded-full"></div>
                  </div>

                  {/* Imagen del Hito */}
                  <div class="w-full md:w-1/2 group">
                    {hito.imagen ? (
                      <div class="relative rounded-2xl overflow-hidden aspect-[4/3] shadow-2xl">
                        <ResponsiveImage 
                          src={hito.imagen?.filename ? `https://warynessy.b-cdn.net/${hito.imagen.filename}` : hito.imagen?.url} 
                          alt={hito.imagen?.alt || hito.titulo}
                          class="w-full h-full object-cover grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000 scale-105 group-hover:scale-100"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                      </div>
                    ) : (
                      <div class="relative rounded-2xl overflow-hidden aspect-[4/3] bg-zinc-900 border border-white/5 flex items-center justify-center shadow-2xl">
                        <span class="material-symbols-outlined text-white/5 text-9xl">history_edu</span>
                      </div>
                    )}
                  </div>

                </div>
              );
            })}
          </div>

        </Container>
      </Section>
    )}

  </div>
</MainLayout>

<style>
  .animate-fade-up {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 1s ease-out forwards;
  }
  
  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import MenuCard from '../../components/content/MenuCard.astro';
import { getSiteSettings, getMenus, getPaginaBySlug, getMenusGrupo } from '../../lib/payload-local';
import { getOptimizedImageUrl } from '../../lib/cdn';
import { getTranslations } from '../../lib/i18n';

const { lang } = Astro.params;
const locale = lang || 'es';

const ui = getTranslations(locale).menus;

// Disable caching to always show fresh content from CMS
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Expires', '0');

let siteSettings, menus = [], menusGrupo = [], pageData;

try {
  [siteSettings, menus, menusGrupo, pageData] = await Promise.all([
    getSiteSettings(locale),
    getMenus(true, locale),
    getMenusGrupo(true, locale),
    getPaginaBySlug('menus', locale)
  ]);
} catch (error) {
  console.error("Error al cargar datos en menus.astro:", error);
}

const pageTitle = pageData?.metaTitle || `Menús | ${siteSettings?.title || "Warynessy"}`;
const pageDescription = pageData?.metaDescription || "Descubre nuestros menús degustación y opciones especiales.";

// Imagen Hero desde el CMS o fallback
const rawHeroImg = typeof pageData?.heroImage === 'object' && pageData?.heroImage?.url
  ? pageData.heroImage.url
  : 'https://images.unsplash.com/photo-1544148103-0773bf10d330?auto=format&fit=crop&q=80';

const heroImg = getOptimizedImageUrl(rawHeroImg, {
  fallback: 'https://images.unsplash.com/photo-1544148103-0773bf10d330?auto=format&fit=crop&q=80'
});


// Obtener IDs de menús que están en grupos para excluirlos de la sección individual
const menuIdsEnGrupos = new Set(
  menusGrupo.flatMap((grupo: any) =>
    (grupo.menus || [])
      .filter((menu: any) => menu && typeof menu === 'object')
      .map((menu: any) => menu.id)
  )
);

// Filtrar menús individuales excluyendo los que están en grupos
const menusIndividuales = menus.filter((menu: any) => !menuIdsEnGrupos.has(menu.id));

// Excluir grupos sin menús (no mostrar si está vacío)
const menusGrupoConMenus = menusGrupo.filter((grupo: any) =>
  (grupo.menus || []).some((m: any) => m && typeof m === 'object')
);
---

<MainLayout title={pageTitle} description={pageDescription} hideFloatingButton={true} noPaddingTop={true}>
    <section class="relative pt-32 pb-6 md:pt-48 md:pb-8 bg-matte-black overflow-hidden">
      <div class="absolute inset-0 bg-cover bg-center opacity-30" style={`background-image: url('${heroImg}')`}></div>
      <div class="absolute inset-0 bg-gradient-to-t from-matte-black via-matte-black/60 to-transparent"></div>
      <Container class="relative z-10 text-center animate-fade-up">
         {pageData?.heroTitle && (
           <h1 class="text-5xl md:text-7xl font-display font-black text-white mb-6 uppercase tracking-tight">
             {pageData.heroTitle}
           </h1>
         )}
         {pageData?.heroSubtitle && (
           <span class="text-primary font-black tracking-[0.3em] uppercase text-sm mb-4 block">
             {pageData.heroSubtitle}
           </span>
         )}
      </Container>
   </section>

   <Section class="bg-matte-black min-h-screen pt-12 pb-24">
     <Container>
       {/* Sección de Menús Individuales */}
       <div class="flex items-center gap-6 mb-12">
         <h2 class="text-3xl md:text-4xl font-display font-black text-white uppercase tracking-tight shrink-0">{pageData?.heroTitle || 'Menús Degustación'}</h2>
         <div class="h-px bg-white/10 w-full"></div>
       </div>

       {menusIndividuales.length > 0 ? (
         <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto mb-24">
           {menusIndividuales.map((menu: any) => (
              <MenuCard menu={menu} locale={locale} />
           ))}
         </div>
       ) : (
         <div class="text-center py-20 mb-24">
           <p class="text-white/40 text-xl">{ui.noMenus}</p>
         </div>
       )}

       {/* Sección de Menús de Grupo */}
       {menusGrupoConMenus && menusGrupoConMenus.length > 0 && (
         <div>
           <div class="flex items-center gap-6 mb-12">
             <h2 class="text-3xl md:text-4xl font-display font-black text-white uppercase tracking-tight shrink-0">{ui.groupsTitle}</h2>
             <div class="h-px bg-white/10 w-full"></div>
           </div>

           <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
             {menusGrupoConMenus.map((grupo: any) => {
               const tieneContrasena = !!grupo.contrasena;
               const rawId = grupo.id;
               return (
               <div
                 class="bg-surface-dark/50 border border-white/5 rounded-[2.5rem] overflow-hidden group hover:border-primary/30 transition-all duration-500 shadow-2xl"
                 data-grupo-id={rawId}
                 data-contrasena={tieneContrasena ? grupo.contrasena : undefined}
               >
                 <div class="relative h-64 overflow-hidden">
                    {(() => {
                      const imgUrl = grupo.imagenPortada?.url
                        || grupo.menus?.find((m: any) => m && typeof m === 'object' && m.imagen?.url)?.imagen?.url;
                      return imgUrl ? (
                        <img
                          src={getOptimizedImageUrl(imgUrl)}
                          alt={grupo.nombre}
                          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                        />
                      ) : null;
                    })()}
                    <div class="absolute inset-0 bg-gradient-to-t from-matte-black via-matte-black/40 to-transparent"></div>
                    <div class="absolute bottom-6 left-8">
                       <h3 class="text-3xl font-display font-black text-white tracking-tight">{grupo.nombre}</h3>
                    </div>
                 </div>

                 <div class="p-8 md:p-10 space-y-8">
                   {grupo.descripcion && (
                     <p class="text-white/60 text-lg font-medium leading-relaxed italic">
                       "{grupo.descripcion}"
                     </p>
                   )}

                   {tieneContrasena ? (
                     /* Overlay de contraseña */
                     <div id={`lock-grupo-${rawId}`} class="grupo-lock-overlay">
                       <div class="flex flex-col items-center gap-5 py-4">
                         <span class="material-symbols-outlined text-primary text-5xl">lock</span>
                         <p class="text-white/60 text-center text-sm">Este contenido está protegido.</p>
                         <div class="flex gap-2 w-full">
                           <input
                             type="password"
                             placeholder="Contraseña"
                             class="grupo-password-input flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-primary/50 transition-colors"
                             data-grupo={rawId}
                           />
                           <button
                             type="button"
                             class="grupo-password-btn bg-primary text-black font-bold px-5 py-3 rounded-xl hover:bg-primary/80 transition-colors"
                             data-grupo={rawId}
                           >
                             <span class="material-symbols-outlined text-xl">arrow_forward</span>
                           </button>
                         </div>
                         <p id={`error-grupo-${rawId}`} class="text-red-400 text-sm hidden">Contraseña incorrecta</p>
                       </div>
                     </div>
                   ) : null}

                   <div id={`content-grupo-${rawId}`} class={tieneContrasena ? 'space-y-4 hidden' : 'space-y-4'}>
                      {grupo.menus?.map((menu: any) => (
                        menu && typeof menu === 'object' && menu.slug ? (
                          <a
                            href={`/${locale}/menus/${menu.slug}`}
                            class="flex items-center justify-between p-5 bg-white/5 rounded-2xl border border-white/5 hover:bg-primary/10 hover:border-primary/20 transition-all group/item"
                          >
                            <div class="flex items-center gap-4">
                              <span class="material-symbols-outlined text-primary text-xl">restaurant_menu</span>
                              <span class="text-white font-bold tracking-tight">{menu.nombre}</span>
                            </div>
                            <div class="flex items-center gap-4">
                              {menu.precio && Number(menu.precio) > 0 && (
                                <span class="text-primary font-black font-display">{menu.precio} €</span>
                              )}
                              <span class="material-symbols-outlined text-white/20 group-hover/item:text-primary group-hover/item:translate-x-1 transition-all">chevron_right</span>
                            </div>
                          </a>
                        ) : null
                      ))}
                   </div>
                 </div>
               </div>
             )})}
           </div>
         </div>
       )}
     </Container>
   </Section>

<script>
  // grupoRawId = el id crudo del documento (e.g. "abc123")
  // En el HTML los IDs son: lock-grupo-{rawId}, content-grupo-{rawId}, error-grupo-{rawId}
  function checkGrupoPassword(rawId: string, inputPassword: string): void {
    const card = document.querySelector(`[data-grupo-id="${rawId}"]`) as HTMLElement | null;
    if (!card) return;

    const correctPassword = card.dataset.contrasena;
    const lockEl = document.getElementById(`lock-grupo-${rawId}`);
    const contentEl = document.getElementById(`content-grupo-${rawId}`);
    const errorEl = document.getElementById(`error-grupo-${rawId}`);

    if (inputPassword === correctPassword) {
      lockEl?.classList.add('hidden');
      contentEl?.classList.remove('hidden');
      errorEl?.classList.add('hidden');
    } else {
      errorEl?.classList.remove('hidden');
    }
  }

  function initGrupoPasswordHandlers() {
    document.querySelectorAll<HTMLButtonElement>('.grupo-password-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const rawId = btn.dataset.grupo!;
        const input = document.querySelector<HTMLInputElement>(`.grupo-password-input[data-grupo="${rawId}"]`);
        if (input) checkGrupoPassword(rawId, input.value);
      });
    });

    document.querySelectorAll<HTMLInputElement>('.grupo-password-input').forEach((input) => {
      input.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') {
          const rawId = input.dataset.grupo!;
          checkGrupoPassword(rawId, input.value);
        }
      });
    });
  }

  // Ejecutar inmediatamente (el script de Astro se ejecuta tras el DOM)
  // y también en navegación con View Transitions si se activan en el futuro
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGrupoPasswordHandlers);
  } else {
    initGrupoPasswordHandlers();
  }
  document.addEventListener('astro:page-load', initGrupoPasswordHandlers);
</script>
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
import Container from '../components/ui/Container.astro';
import { getSiteSettings, getPaginaBySlug, getEspacios } from '../lib/payload-local';
import { getOptimizedImageUrl } from '../lib/cdn';

const locale = 'es';

const ui = getTranslations(locale).espacios;
const common = getTranslations(locale).common;

const [siteSettings, pageData, espaciosData] = await Promise.all([
  getSiteSettings(locale),
  getPaginaBySlug('espacios', locale),
  getEspacios(true, locale),
]);

const pageTitle = pageData?.metaTitle || `${ui.title} | ${siteSettings?.title || "Restaurante Warynessy"}`;
const pageDescription = pageData?.metaDescription || "Descubre los espacios únicos y exclusivos de Restaurante Warynessy. Salones diseñados para experiencias gastronómicas memorables.";

// Build spaces list: prefer pagina data, fall back to espacios collection
const spacesFromPagina = [
  { nombre: pageData?.nombreEspacio1, descripcion: pageData?.descripcionEspacio1, imagen: pageData?.imagenEspacio1 },
  { nombre: pageData?.nombreEspacio2, descripcion: pageData?.descripcionEspacio2, imagen: pageData?.imagenEspacio2 },
  { nombre: pageData?.nombreEspacio3, descripcion: pageData?.descripcionEspacio3, imagen: pageData?.imagenEspacio3 },
  { nombre: pageData?.nombreEspacio4, descripcion: pageData?.descripcionEspacio4, imagen: pageData?.imagenEspacio4 },
].filter(s => s.nombre && s.imagen);

const spaces = spacesFromPagina.length > 0
  ? spacesFromPagina
  : (espaciosData || []).map((e: any) => ({
      nombre: e.nombre,
      descripcion: e.descripcion,
      imagen: typeof e.imagenPrincipal === 'object' ? e.imagenPrincipal : null,
    }));
---

<MainLayout title={pageTitle} description={pageDescription}>

  <div class="bg-[#0A0A0A] min-h-screen pt-32 pb-32">
    <Container>
      <!-- Hero Section -->
      <section class="mb-20 animate-fade-up">
        <h1 class="text-6xl md:text-8xl font-display font-black text-white mb-8 uppercase tracking-tighter leading-[0.9]">
          {((pageData?.heroTitle || ui.title)).split(' ')[0]} <br/>
          <span class="text-[#D12026]">{((pageData?.heroTitle || ui.title)).split(' ').slice(1).join(' ')}</span>
        </h1>
        <div class="w-24 h-1 bg-[#D12026] mb-8"></div>
        {pageData?.heroSubtitle && (
          <p class="text-gray-400 text-xl font-light leading-relaxed max-w-2xl italic">
            "{pageData.heroSubtitle}"
          </p>
        )}
      </section>

      <!-- Spaces Cards List -->
      <div class="flex flex-col gap-12">
        {spaces.map((item, index) => (
          <div class="group bg-[#111] rounded-[2rem] overflow-hidden border border-white/5 flex flex-col lg:flex-row animate-fade-up shadow-2xl transition-all duration-500 hover:border-white/10" style={`animation-delay: ${index * 150}ms`}>
            <!-- Image Section -->
            <div class="w-full lg:w-[500px] aspect-[4/3] lg:aspect-square overflow-hidden relative">
               <img
                src={getOptimizedImageUrl(item.imagen?.url) || '/images/placeholder-space.jpg'}
                alt={item.nombre}
                class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 group-hover:rotate-1"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A]/80 via-transparent to-transparent opacity-60"></div>

              <!-- Number Indicator (Stitch Style) -->
              <div class="absolute bottom-6 left-6 flex items-center gap-3">
                <span class="text-white/20 font-display font-black text-6xl italic leading-none">0{index + 1}</span>
              </div>
            </div>

            <!-- Content Section -->
            <div class="p-8 lg:p-16 flex flex-col justify-center flex-1 relative">
              <div class="mb-4">
                <h2 class="text-4xl md:text-5xl font-display font-black text-white uppercase tracking-tight group-hover:text-[#D12026] transition-colors duration-500 mb-2">
                  {item.nombre}
                </h2>
                <div class="w-12 h-0.5 bg-white/10 group-hover:w-24 group-hover:bg-[#D12026] transition-all duration-700"></div>
              </div>

              <p class="text-gray-400 text-lg font-light leading-relaxed mb-10 max-w-xl">
                {item.descripcion}
              </p>



              <!-- Action Button -->
              <div class="mt-12 flex items-center gap-4">
                <a href={`/reservas`} class="inline-flex items-center gap-3 text-[#D12026] text-xs font-black uppercase tracking-[0.3em] hover:gap-5 transition-all duration-300">
                  <span>{ui.bookRoom || "Reservar Espacio"}</span>
                  <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>


    </Container>
  </div>

</MainLayout>

<style>
  /* Import Material Symbols */
  @import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200');

  /* Animaciones */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fade-up 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .material-symbols-outlined {
    font-variation-settings:
      'FILL' 0,
      'wght' 300,
      'GRAD' 0,
      'opsz' 24
  }
</style>
